## ---------------------------------------------
## .gitignore para proyectos .NET (Visual Studio)
## ---------------------------------------------

# Build output
[Bb]in/
[Oo]bj/
[Oo]ut/
[Ll]og/
[Ll]ogs/
[Dd]ebug/
[Rr]elease/
[Dd]ebugPublic/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
msbuild.log
msbuild.err
msbuild.wrn

# Visual Studio / Rider / VS Code cache
.vs/
.vscode/
.idea/
*.suo
*.user
*.userosscache
*.sln.docstates
*.userprefs
.builds

# ReSharper
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# NuGet
*.nupkg
*.snupkg
# ignoramos el folder pero permitimos el archivo de targets si lo usan
**/[Pp]ackages/*
!**/[Pp]ackages/build/
*.nuget.props
*.nuget.targets
project.lock.json
project.fragment.lock.json
artifacts/

# Compiled code / binarios
*.dll
*.exe
*.pdb
*.ilk
*.meta
*.obj
*.iobj
*.ipdb
*.tlb
*.tli
*.tlh
*.cache
*.lib
*.sbr

# Test results & coverage
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
*.VisualState.xml
TestResult.xml
nunit-*.xml
coverage*.json
coverage*.xml
coverage*.info
*.coverage
*.coveragexml

# WinForms / WPF / Blend
*.StyleCop
*.binlog
*.rptproj.rsuser
*.Designer.cs.bak

# Publish profiles (contienen credenciales)
*.[Pp]ublish.xml
*.pubxml
*.pubxml.user
PublishScripts/
*.azurePubxml

# Archivos locales sensibles
appsettings.*.Local.json
appsettings.Development.json
secrets.json
*.pfx
*.snk

# OS
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# Temp
*.tmp
*.temp
*.bak
*.swp
*~
